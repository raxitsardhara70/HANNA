{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "outDir": "dist",
    "paths": {
      "@components/*": ["./components/*"],
      "@contexts/*": ["./contexts/*"],
      "@desktop/*": ["./*"],
      "@hooks/*": ["./hooks/*"],
      "@layouts/*": ["./layouts/*"],
      "@pages/*": ["./pages/*"],
      "@renderer/*": ["./renderer/*"],
      "@services/*": ["./services/*"],
      "@stores/*": ["./stores/*"],
      "@styles/*": ["./styles/*"],
      "@types/*": ["./types/*"],
      "@utils/*": ["./utils/*"]
    },
    "rootDir": ".",
    "types": ["node", "vite/client"]
  },
  "references": [
    { "path": "../../packages/types" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/logger" },
    { "path": "../../packages/config" },
    { "path": "../../packages/ipc" },
    { "path": "../../packages/ui" }
  ],
  "include": ["main", "preload", "renderer", "components", "layouts", "pages", "hooks", "contexts", "stores", "styles", "ipc", "services", "utils", "types", "vite.config.ts"]
}
